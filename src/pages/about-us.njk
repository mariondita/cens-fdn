---
pagination:
  data: languages
  size: 1
  alias: lang
permalink: "/{{ lang.code }}/about-us/index.html"
layout: layouts/page.njk
pageKey: "about-us"
---

{% set t = i18n[lang.code] %}
{% set title = t.about.title %}
{% set metaDesc = t.about.metaDesc %}
{% set introHeading = t.about.title %}

<div class="[ post__body ] [ inner-wrapper ] [ leading-loose pad-top-300 pad-bottom-900 text-500 ] [ sf-flow ] [ e-content ]">
  <h2>{{ t.about.missionHeading }}</h2>
  {{ t.about.missionBody | markdownFilter | safe }}

  <h2>{{ t.about.teamHeading }}</h2>
  <div class="team-grid">
    {% for member in t.about.team %}
    <article class="team-card">
      <div class="team-card__image">
        <img src="/images/team/{{ member.image }}" alt="{{ member.name }}" loading="lazy">
      </div>
      <h3 class="team-card__name">{{ member.name }}</h3>
      <p class="team-card__title">{{ member.role }}</p>
      <p class="team-card__description">{{ member.bio }}</p>
      <a href="{{ member.profileUrl or '#' }}" class="team-card__link">{{ t.about.viewProfile }}</a>
    </article>
    {% endfor %}
  </div>
</div>
