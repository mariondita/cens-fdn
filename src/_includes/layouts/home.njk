{% extends 'layouts/base.njk' %}

{# Intro content (allow child to set introHeading/introSummary via t) #}
{% set introHeading = introHeading or title %}
{% set introSummary = introSummary or (content | safe) %}

{% block content %}
  <main id="main-content" tabindex="-1">
    {% include "partials/components/intro.njk" %}
    
    <div class="[ inner-wrapper ] [ sf-flow ]">
      <div class="feature-card">
        <div class="feature-card__image">
          <img src="/images/cosmo-caixa.jpg" alt="{{ t.home.featureCaption if t else 'Linda Liukas STEAMConf 2017' }}" loading="lazy">
          <p class="feature-card__caption">{{ t.home.featureCaption if t else 'Linda Liukas STEAMConf 2017' }}</p>
        </div>
        <div class="feature-card__content">
          <h2 class="feature-card__title">{{ t.home.featureTitle if t else 'STEAMConf 2025' }}</h2>
          <p class="feature-card__description">{{ t.home.featureDescription if t else "10a conferència Internacional d'aprenentatge, 5, 6, 7 i 8 de novembre 2025." }}</p>
          <a href="http://www.steamconf.com/">{{ t.home.featureLink if t else 'Coneix la Conferència' }}</a>
        </div>
      </div>
    </div>
  </main>
{% endblock %}
