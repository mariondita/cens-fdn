{% set currentLang = lang | default({ code: "ca", name: "Català", default: true }) %}
{% set langT = i18n[currentLang.code] %}
{% if langT and title is undefined and pageKey is defined %}
{% if pageKey == "" %}
{% set title = langT.home.title %}
{% elif pageKey == "about-us" %}
{% set title = langT.about.title %}
{% elif pageKey == "contact" %}
{% set title = langT.contact.title %}
{% endif %}
{% endif %}
{% if langT %}
{% set navItems = [
  { text: langT.nav.home, url: "/" + currentLang.code + "/" },
  { text: langT.nav.about, url: "/" + currentLang.code + "/about-us/" },
  { text: langT.nav.contact, url: "/" + currentLang.code + "/contact/" }
] %}
{% endif %}
<!DOCTYPE html>
<html lang="{{ currentLang.code }}" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <link rel="alternate" type="application/rss+xml" title="{{ site.name }}" href="{{ site.url }}/feed.xml" />
  <link rel="icon" href="{{ site.faviconPath }}" type="image/png" />
  {% if lang and pageKey is defined %}
  {% for l in languages %}
  <link rel="alternate" hreflang="{{ l.code }}" href="{{ site.url }}/{{ l.code }}/{% if pageKey %}{{ pageKey }}/{% endif %}" />
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}/ca/{% if pageKey %}{{ pageKey }}/{% endif %}" />
  {% endif %}
  {% include "partials/global/meta-info.njk" %}
  <script>document.documentElement.classList.remove('no-js');</script>
  <style>{% include "assets/css/global.css" %}</style>
  {% block head %}
  {% endblock %}
</head>
<body>
  {% include "partials/global/site-head.njk" %}
  {% block content %}
  {% endblock content %}
  {% include "partials/global/site-foot.njk" %}
  {% block foot %}
  {% endblock %}

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js');
      });
    }
    // Language dropdown: toggle on button click, close on outside click
    (function() {
      var trigger = document.querySelector('.lang-dropdown__trigger');
      var dropdown = document.querySelector('.lang-dropdown');
      if (!trigger || !dropdown) return;
      trigger.addEventListener('click', function() {
        var open = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', !open);
        dropdown.setAttribute('data-open', !open ? 'true' : 'false');
      });
      document.addEventListener('click', function(e) {
        if (!dropdown.contains(e.target)) {
          trigger.setAttribute('aria-expanded', 'false');
          dropdown.setAttribute('data-open', 'false');
        }
      });
    })();
  </script>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
</body>
</html>
