{% set currentLang = lang | default({ code: "ca", name: "Català", default: true }) %}
{% set navItems = navItems | default(navigation.items) %}
{% set siteNameForLang = t.siteName if t else site.name %}
{% set homeLabel = t.common.home if t else "Home" %}
<a class="skip-link" href="#main-content">{{ t.common.skipToContent if t else "Skip to content" }}</a>
<header role="banner" class="[ site-head ] [ pad-top-700 pad-bottom-700 ]">
  <div class="wrapper">
    <div class="[ site-head__inner ] [ md:box-flex space-between align-center ]">
      <a href="/{{ currentLang.code }}/" class="[ site-head__site-name ] [ leading-tight ] [ box-flex align-center ]">
        <img src="/images/CenS.png?v=1" alt="{{ siteNameForLang }} Logo" class="[ site-head__logo ] [ max-width-150 ]" loading="lazy">
        <span class="visually-hidden">{{ siteNameForLang }} - {{ homeLabel }}</span>
      </a>
      {% set ariaLabel = 'navigation' %}
      {% include "partials/components/nav.njk" %}
      {% if languages and lang %}
      <div class="lang-dropdown">
        <button type="button" class="lang-dropdown__trigger" aria-expanded="false" aria-haspopup="true" aria-label="Choose language" title="Choose language">
          {% include "icons/globe.svg" %}
        </button>
        <ul class="lang-dropdown__list" role="menu" aria-label="Language options">
          {% for l in languages %}
          <li role="none">
            <a href="/{{ l.code }}/{% if pageKey %}{{ pageKey }}/{% endif %}" role="menuitem"{% if l.code == currentLang.code %} aria-current="page"{% endif %} class="lang-dropdown__link" title="{{ l.name }}">{{ l.menu }}</a>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </div>
</header>
